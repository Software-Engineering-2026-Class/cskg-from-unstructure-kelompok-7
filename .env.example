# Required for Gemini/LangChain extraction
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Internal service URLs used by the Docker Compose network
REDIS_HOST=redis
REDIS_PORT=6379
VIRTUOSO_SPARQL_ENDPOINT=http://virtuoso:8890/sparql
VIRTUOSO_GRAPH=http://group2.org/cskg

# Virtuoso default credential used by compose.yml for local development
DBA_PASSWORD=mysecretpassword

# Optional runtime tuning
PRODUCER_INTERVAL_SECONDS=300
SUMMARY_INTERVAL_SECONDS=86400
